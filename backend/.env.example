APP_NAME=AI赋能智能简历分析系统
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=postgresql+psycopg2://postgres:123456@postgres:5432/ai_resume_analyze
REDIS_URL=redis://:123456@redis:6379/0
REDIS_TTL_SECONDS=86400
ALLOWED_ORIGINS=https://your-domain.com

AI_API_URL=
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_SECONDS=45
AI_TEMPERATURE=0.2
AI_REQUEST_PATH=choices.0.message.content

SERVERLESS_STAGE=docker
GITHUB_PAGES_BASE=./
MAX_UPLOAD_SIZE_MB=10
RESUME_STORAGE_DIR=/app/storage/resumes
DOCS_URL=/docs
OPENAPI_URL=/openapi.json
REDOC_URL=/redoc
