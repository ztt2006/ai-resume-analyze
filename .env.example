APP_NAME=AI赋能智能简历分析系统
APP_VERSION=1.0.0
DEBUG=false
API_PREFIX=/api

POSTGRES_DB=ai_resume_analyze
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456

REDIS_PASSWORD=123456
